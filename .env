# 🛡️ Aegis-Antigravity SRE Environment Configurations
# Add your credentials below to transition the engine from mock to live mode.

# 1. SRE Brain API key (Accepts Google Gemini 'AIzaSy...' keys or OpenAI 'sk-...' keys)
OPENAI_API_KEY=AIzaSyClcn0EcfdpLE9SQEYAUACQtPLiANBg1EY

# 2. Cognitive Model selection (e.g. gemini-3.1-flash-lite, gemini-2.5-flash-lite, gemma-4-31b-it)
SRE_LLM_MODEL=gemini-3.1-flash-lite

# 3. Resilient n8n remediation webhook URL (By default triggers local port 5678)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/aegis-sre-remediate
DISABLE_N8N=true
